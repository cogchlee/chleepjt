# =============================================
# YouTube Personal Agent - Environment Variables
# Copy this file to .env and fill in your values
# =============================================

# --- Google OAuth 2.0 (YouTube Comment Posting) ---
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here
# For headless server (Oracle Cloud), use OOB flow
GOOGLE_REDIRECT_URI=urn:ietf:wg:oauth:2.0:oob

# --- YouTube API ---
YOUTUBE_API_KEY=your_youtube_data_api_v3_key
# Comma-separated channel IDs to target for commenting
TARGET_CHANNEL_IDS=UCxxxxxxxxxxxxxxxx,UCyyyyyyyyyyyyyy
# Your own channel ID (for style learning from past comments)
MY_CHANNEL_ID=UCzzzzzzzzzzzzzzzz

# --- Google Gemini ---
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# --- Telegram ---
TELEGRAM_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your personal chat ID (get from @userinfobot)
TELEGRAM_CHAT_ID=123456789

# --- Scheduler Settings ---
# Interval between comment posting cycles (hours)
SCHEDULE_INTERVAL_HOURS=3
# Random jitter range in minutes added to each cycle (anti-bot)
SCHEDULE_JITTER_MINUTES=30
# Etiquette hours (KST, 24h format) - no comments outside this window
ETIQUETTE_START_HOUR=8
ETIQUETTE_END_HOUR=23

# --- File Paths ---
DATA_DIR=./data
LOG_DIR=./logs
DB_PATH=./data/agent.db
TOKEN_PATH=./data/token.json
